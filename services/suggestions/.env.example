SUPABASE_DB_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres
# REDIS_URL: solo host:port (sin prefijo redis://)
# En Docker usa el nombre del servicio: redis:6379
# En Render/Upstash usa: your-host.upstash.io:6379
REDIS_URL=localhost:6379
PORT=8080
FRONTEND_ORIGIN=http://localhost:3000
